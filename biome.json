{
    "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
    "files": {
        "includes": ["ExtensionSource/**/*.{js,jsx}", "Scripts/**/*.{js,mjs}"]
    },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "none"
        }
    }
}
